#!/usr/bin/env bash
set -euxo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update
rm -rf /var/lib/apt/lists/*

# --- Install VS Code (Debian/Ubuntu) ---
# Download the official .deb and install with apt so dependencies are resolved.
# (Avoid dpkg -i here; apt handles deps automatically.)
TMP_DEB=/tmp/vscode.deb
curl -fL -o "${TMP_DEB}" https://go.microsoft.com/fwlink/?LinkID=760868
apt-get update
apt-get install -y --no-install-recommends "${TMP_DEB}"
rm -f "${TMP_DEB}"
rm -rf /var/lib/apt/lists/*
# Tip: if you prefer the Microsoft APT repo for automatic updates,
# follow the upstream guide to add their repo/GPG key instead. :contentReference[oaicite:2]{index=2}

# --- Install VS Code Python extensions into a baked-in extensions dir ---
# Extensions live under /opt so they ride with the docker image and stay in
# sync with this postInstall; the runtime launcher points at them via
# --extensions-dir.
VSCODE_EXTDIR=/opt/vscode-extensions
mkdir -p "${VSCODE_EXTDIR}"
VSCODE_BUILD_FLAGS=(--no-sandbox --user-data-dir=/tmp/vscode-build --extensions-dir="${VSCODE_EXTDIR}")
code "${VSCODE_BUILD_FLAGS[@]}" --install-extension ms-python.python
code "${VSCODE_BUILD_FLAGS[@]}" --install-extension ms-python.debugpy
rm -rf /tmp/vscode-build

# --- Install uv (unmanaged so it doesn't touch shell profiles during image build) ---
# This puts 'uv' at /usr/local/bin and avoids profile edits in a non-interactive build.
curl -LsSf https://astral.sh/uv/install.sh | env UV_UNMANAGED_INSTALL=/usr/local/bin sh
uv --version  # sanity check
# (Unmanaged installs skip self-updates; you can still rerun the installer later.) :contentReference[oaicite:3]{index=3}

# --- Clone your GUI and install its environment with uv ---
# If you want a fixed path that’s not root’s home, /opt is conventional.
#git clone --filter=blob:none --single-branch --branch fix/histology-offsets \
#  https://github.com/AllenNeuralDynamics/ibl-ephys-alignment-gui \
#  /opt/ibl-ephys-alignment-gui
git clone --filter=blob:none --branch main \
  https://github.com/AllenNeuralDynamics/ibl-ephys-alignment-gui \
  /opt/ibl-ephys-alignment-gui

pushd /opt/ibl-ephys-alignment-gui
# Create a project-local venv and resolve/install from pyproject/uv.lock (if present)
uv sync
uv pip install --system .
# Optional: if you want a pinned Python for the project, let uv fetch it:
# uv python install 3.12
# uv sync --python 3.12
popd

# --- Pre-configure VS Code workspace so debugging is one-click ---
mkdir -p /opt/ibl-ephys-alignment-gui/.vscode

cat > /opt/ibl-ephys-alignment-gui/.vscode/launch.json <<'JSON'
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: IBL Ephys Alignment GUI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/launch.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "/opt/conda/bin/python"
        }
    ]
}
JSON

cat > /opt/ibl-ephys-alignment-gui/.vscode/settings.json <<'JSON'
{
    "python.defaultInterpreterPath": "/opt/conda/bin/python",
    "python.terminal.activateEnvironment": false
}
JSON

# --- Wrapper that encapsulates the Code Ocean-specific VS Code launch dance ---
cat > /usr/local/bin/code-debug <<'SH'
#!/usr/bin/env bash
# Launch VS Code in the Code Ocean root-desktop session:
#   - --no-sandbox is required when running as root
#   - --user-data-dir=/scratch keeps VS Code state on the persistent scratch
#     mount (survives across capsule runs, unlike /root)
#   - extensions live in the baked-in /opt/vscode-extensions
#   - gnome-keyring-daemon is unlocked with an empty password so VS Code's
#     secret storage doesn't prompt
#   - core dumps are suppressed
set -e

ulimit -c 0

mkdir -p /scratch

if command -v gnome-keyring-daemon >/dev/null 2>&1; then
    eval "$(printf '\n' | gnome-keyring-daemon --unlock --components=secrets,pkcs11,ssh 2>/dev/null)" || true
    export SSH_AUTH_SOCK
fi

exec code \
    --no-sandbox \
    --user-data-dir=/scratch \
    --extensions-dir=/opt/vscode-extensions \
    "${@:-/opt/ibl-ephys-alignment-gui}"
SH
chmod +x /usr/local/bin/code-debug

# --- Desktop launcher for the Guacamole graphical session ---
mkdir -p /root/Desktop
cat > /root/Desktop/Debug-IBL-GUI.desktop <<'DESKTOP'
[Desktop Entry]
Version=1.0
Type=Application
Name=Debug IBL GUI
Comment=Open ibl-ephys-alignment-gui in VS Code with the debugger pre-configured
Exec=/usr/local/bin/code-debug /opt/ibl-ephys-alignment-gui
Icon=code
Terminal=false
Categories=Development;
DESKTOP
chmod +x /root/Desktop/Debug-IBL-GUI.desktop

# --- Autostart: mark desktop launchers as trusted so they don't prompt ---
# gio set requires a running gvfs daemon (over dbus), which only exists at
# session time — not during the docker build. So we drop a helper script and
# an XDG autostart entry that runs it on session start, marking every
# ~/Desktop/*.desktop as trusted under both the GNOME (metadata::trusted) and
# XFCE (metadata::xfce-exe-checksum) conventions.
cat > /usr/local/bin/trust-desktop-launchers <<'SH'
#!/usr/bin/env bash
shopt -s nullglob
for f in "$HOME"/Desktop/*.desktop; do
    chmod +x "$f"
    gio set "$f" metadata::trusted true 2>/dev/null || true
    exec_line=$(sed -n 's/^Exec=//p' "$f" | head -n1)
    if [ -n "$exec_line" ]; then
        checksum=$(printf %s "$exec_line" | sha256sum | awk '{print $1}')
        gio set "$f" metadata::xfce-exe-checksum "$checksum" 2>/dev/null || true
    fi
done
SH
chmod +x /usr/local/bin/trust-desktop-launchers

mkdir -p /root/.config/autostart
cat > /root/.config/autostart/trust-desktop-launchers.desktop <<'AUTOSTART'
[Desktop Entry]
Type=Application
Name=Trust Desktop Launchers
Exec=/usr/local/bin/trust-desktop-launchers
X-GNOME-Autostart-enabled=true
NoDisplay=true
AUTOSTART
